# Flask Environment
FLASK_ENV=development
PORT=5000

# Security Keys
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT Token Expiration (seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database
DATABASE_URL=sqlite:///minimart.db
# Example for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/minimart

# File Upload Settings
UPLOAD_FOLDER=uploads/products
MAX_CONTENT_LENGTH=16777216

# CORS
# Comma-separated origins
CORS_ORIGINS=*
# Example:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Third-party API Keys
#https://dashboard.stripe.com/acct_1TKb0bFRnhRVSYqI/test/atlas/join
#STRIPE_API_KEY=put_your_stripe_key_here